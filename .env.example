# Combined reference for local development.
# Prefer app/.env.local and api/.env.local during day-to-day work.

# App runtime
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_KEY=replace-with-local-publishable-key-from-supabase-start
EXPO_PUBLIC_AUTH_REDIRECT_URL=freshcycle://auth/callback

# API runtime
API_PORT=8080
SUPABASE_DB_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_JWT_SECRET=replace-when-backend-jwt-validation-is-added
